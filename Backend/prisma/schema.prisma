generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum UserRole {
  owner
  salesperson
}

// Stored values match the existing Mongoose string values so app code needs
// minimal changes when Prisma queries replace Mongoose queries.
enum PipelineStage {
  Lead
  Contacted
  Interested
  ProposalSent @map("Proposal Sent")
  Negotiation
  ClosedWon    @map("Closed Won")
  ClosedLost   @map("Closed Lost")
}

enum InvoiceStatus {
  Draft
  Sent
  PartiallyPaid @map("Partially Paid")
  Paid
  Overdue
  Cancelled
}

enum SubscriptionStatus {
  Active
  Renewed
  Cancelled
  Expired
}

enum NotificationType {
  followup
  invoice
  renewal
  email_reply
}

enum GmailConnectionStatus {
  connected
  disconnected
  error
}

enum EmailMessageDirection {
  outbound
  inbound
}

enum FollowUpHistoryType {
  scheduled
  reminder_sent
  closed_lost
  closed_won
}

enum InvoiceActivityType {
  sent
  emailed
  reminder
}

enum EmailTemplateType {
  welcome
  followup
  invoice_reminder
  renewal
  thank_you
  custom
}

enum AdProvider {
  facebook
  google
}

enum AdChatRole {
  user
  assistant
}

enum AdAccountStatus {
  active
  disconnected // token expired / revoked — re-auth required
  error
}

enum CampaignStatus {
  draft
  scheduled
  sending
  sent
  partially_sent
}

enum EmailLogStatus {
  queued
  sent
  delivered
  opened
  clicked
  bounced
  complained
  failed
}

// ── Models ────────────────────────────────────────────────────────────────────

// Owner account. No businessId FK — this IS the tenant root.
model Business {
  id           String @id @default(cuid())
  businessName String
  email        String @unique
  passwordHash String

  // Branding & company info for invoices (§5 / §12.1)
  logoUrl                   String @default("")
  addressLine               String @default("")
  country                   String @default("")
  phone                     String @default("")
  website                   String @default("")
  gstNumber                 String @default("")
  pstNumber                 String @default("")
  defaultTaxRate            Float  @default(0)
  province                  String @default("") // 2-letter Canadian province code
  defaultCustomerNote       String @default("")
  defaultTerms              String @default("")
  invoiceNumberPrefix       String @default("INV-")
  invoiceNumberPadding      Int    @default(3)
  invoiceNumberCurrentValue Int    @default(0)

  // Encrypted Claude API key for AI analysis (§12c.1). AES-256-GCM, never returned to frontend.
  claudeApiKey String @default("")

  // Per-business Resend sender (owner registers their OWN Resend account/domain).
  // AES-256-GCM encrypted, never returned to frontend. Falls back to the shared
  // RESEND_API_KEY / RESEND_FROM_EMAIL in .env when empty.
  resendApiKey    String @default("")
  resendFromEmail String @default("")
  resendFromName  String @default("")

  // DEPRECATED — SMTP sending has been replaced by Resend (see ResendEmailService).
  // Columns kept (unused) to avoid a destructive migration on existing data.
  smtpHost     String  @default("")
  smtpPort     Int     @default(587)
  smtpSecure   Boolean @default(false)
  smtpUser     String  @default("")
  smtpPassword String  @default("") // AES-256-GCM encrypted, never returned to frontend
  smtpFromName String  @default("")

  // Configurable day-offset schedules (§7.4); Json keeps them editable without schema changes
  reminderSchedule Json @default("{\"invoiceReminderDays\":[1,2,4,7,14],\"renewalReminderDays\":[30,14,7,3,1]}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                User[]
  customers            Customer[]
  invoices             Invoice[]
  services             Service[]
  subscriptions        Subscription[]
  notifications        Notification[]
  emailTemplates       EmailTemplate[]
  emailCampaigns       EmailCampaign[]
  emailLogs            EmailLog[]
  adConnections        AdConnection[]
  adAccounts           AdAccount[]
  campaigns            Campaign[]
  adAnalyses           AdAnalysis[]
  adChatMessages       AdChatMessage[]
  adBatchAnalyses      AdBatchAnalysis[]
  adBatchChatMessages  AdBatchChatMessage[]
  campaignKeywords     CampaignKeyword[]
  campaignSearchTerms  CampaignSearchTerm[]
  campaignTargetings   CampaignTargeting[]
  campaignDemographics CampaignDemographic[]
  followUpHistory      FollowUpHistory[]
  invoiceActivities    InvoiceActivity[]
  gmailConnection      GmailConnection?
  emailMessages        EmailMessage[]
}

// Salesperson / owner staff account (§4 / §5)
model User {
  id           String   @id @default(cuid())
  businessId   String
  fullName     String   @default("")
  email        String   @unique
  passwordHash String
  role         UserRole @default(salesperson)

  // Owner-configurable permission flags (§4); Json — the owner toggles flags per staff member
  permissions Json @default("{\"viewAllCustomers\":false,\"manageCustomers\":true,\"sendEmail\":true,\"manageEmailTemplates\":false,\"createInvoice\":true,\"exportInvoicePdf\":false,\"manageServices\":false,\"viewReports\":false,\"exportExcel\":false,\"importData\":false,\"analyzeAds\":false,\"manageStaff\":false}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business            Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customers           Customer[]           @relation("AssignedSalesperson")
  notifications       Notification[]
  emailTemplates      EmailTemplate[]
  emailCampaigns      EmailCampaign[]
  adAnalyses          AdAnalysis[]
  adChatMessages      AdChatMessage[]
  adBatchAnalyses     AdBatchAnalysis[]
  adBatchChatMessages AdBatchChatMessage[]
  adConnections       AdConnection[] // OAuth logins this staff member made (owns the tokens)
  adAccountAccess     AdAccountAccess[] // fanpages/ad accounts shared TO this staff member

  @@index([businessId])
}

// Lead / potential customer (§5 / §6)
model Customer {
  id              String        @id @default(cuid())
  businessId      String
  assignedToId    String // FK to User (the salesperson)
  customerName    String
  shopName        String        @default("")
  shopAddress     String        @default("") // street + city + province + postal code
  email           String        @default("")
  phoneNumber     String        @default("")
  shopPhoneNumber String        @default("")
  contactSource   String        @default("")
  dateOfContact   DateTime?
  stage           PipelineStage @default(Lead)
  status          String        @default("") // free-text label e.g. 'Interested', 'Potential'
  note            String        @default("")
  nextFollowUpAt  DateTime?
  isClosed        Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  business        Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  assignedTo      User              @relation("AssignedSalesperson", fields: [assignedToId], references: [id])
  invoices        Invoice[]
  subscriptions   Subscription[]
  emailLogs       EmailLog[]
  followUpHistory FollowUpHistory[]
  emailMessages   EmailMessage[]

  @@index([businessId])
  @@index([assignedToId])
  @@index([businessId, assignedToId])
}

// Company service catalog (§5, owner-managed)
model Service {
  id         String   @id @default(cuid())
  businessId String
  name       String
  price      Decimal  @db.Decimal(12, 2)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business      Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  lineItems     InvoiceLineItem[]
  subscriptions Subscription[]

  @@index([businessId])
}

// Invoice header (§5 / §12.2). Money fields are all server-computed — never trust client totals.
model Invoice {
  id            String @id @default(cuid())
  businessId    String
  customerId    String
  invoiceNumber String

  invoiceDate DateTime
  dueDate     DateTime?
  terms       String    @default("") // e.g. 'Due on Receipt', 'Net 30'

  // Snapshot of the customer's billing address at creation time (§5)
  // Stored as Json so the invoice stays correct even if the customer record changes.
  billTo Json @default("{\"name\":\"\",\"addressLine\":\"\",\"email\":\"\",\"phone\":\"\"}")

  // Money totals — all Decimal for exactness (§5)
  subTotal        Decimal @default(0) @db.Decimal(12, 2)
  discount        Float   @default(0) // percent 0–100
  shippingCharges Decimal @default(0) @db.Decimal(12, 2)
  adjustment      Decimal @default(0) @db.Decimal(12, 2) // can be negative
  taxRate         Float   @default(0) // percent 0–100
  province        String  @default("") // 2-letter Canadian province code
  taxLabel        String  @default("") // e.g. 'GST', 'HST', 'GST + PST'
  taxAmount       Decimal @default(0) @db.Decimal(12, 2)
  total           Decimal @default(0) @db.Decimal(12, 2)
  amountPaid      Decimal @default(0) @db.Decimal(12, 2)
  balanceDue      Decimal @default(0) @db.Decimal(12, 2)

  customerNote    String @default("")
  termsConditions String @default("") // GST/PST registration numbers etc.
  attachments     Json   @default("[]") // [{ filename, path, mimeType, size }]

  status              InvoiceStatus @default(Draft)
  dateSent            DateTime?
  nextReminderAt      DateTime?
  lastReminderAt      DateTime?
  reminderStep        Int           @default(0)
  promisedPaymentDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business      Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer      Customer          @relation(fields: [customerId], references: [id])
  lineItems     InvoiceLineItem[]
  payments      Payment[]
  subscriptions Subscription[]
  activities    InvoiceActivity[]

  @@unique([businessId, invoiceNumber])
  @@index([businessId])
  @@index([customerId])
  @@index([businessId, status])
  @@index([nextReminderAt])
  @@index([dateSent])
}

model FollowUpHistory {
  id                  String              @id @default(cuid())
  businessId          String
  customerId          String
  actorUserId         String?
  type                FollowUpHistoryType
  note                String              @default("")
  nextFollowUpAt      DateTime?
  reminderTriggeredAt DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([customerId, createdAt])
}

// Normalized line items — child table instead of embedded array (§5 / CLAUDE.md rule)
model InvoiceLineItem {
  id          String   @id @default(cuid())
  invoiceId   String
  serviceId   String? // null → manually-entered item; set → picked from Service catalog
  description String
  serviceTerm String   @default("") // e.g. 'June 15, 2026 - June 14, 2027'
  quantity    Float
  rate        Decimal  @db.Decimal(12, 2)
  amount      Decimal  @db.Decimal(12, 2) // server-computed: quantity * rate
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
}

// Normalized payment history — child table instead of embedded array (§5 / §7.2 / CLAUDE.md rule)
model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  date      DateTime
  amount    Decimal  @db.Decimal(12, 2)
  method    String   @default("") // e.g. 'Cash', 'Bank Transfer', 'E-Transfer', 'Cheque'
  note      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model InvoiceActivity {
  id              String              @id @default(cuid())
  businessId      String
  invoiceId       String
  actorUserId     String?
  type            InvoiceActivityType
  note            String              @default("")
  balanceSnapshot Decimal?            @db.Decimal(12, 2)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoice  Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([invoiceId, createdAt])
}

// Closed deal / active service subscription (§5 / §7.3)
model Subscription {
  id             String             @id @default(cuid())
  businessId     String
  customerId     String
  serviceId      String
  servicePrice   Decimal            @db.Decimal(12, 2) // snapshot of price at closing time
  invoiceId      String?
  closingDate    DateTime?
  startDate      DateTime?
  expiryDate     DateTime // drives renewal reminders
  status         SubscriptionStatus @default(Active)
  nextReminderAt DateTime?
  reminderStep   Int                @default(0)
  note           String             @default("")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])
  service  Service  @relation(fields: [serviceId], references: [id])
  invoice  Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([businessId])
  @@index([customerId])
  @@index([businessId, customerId])
  @@index([expiryDate])
}

// In-app notification (§8 / §7)
model Notification {
  id           String           @id @default(cuid())
  businessId   String
  targetUserId String
  type         NotificationType
  message      String
  relatedId    String? // cuid of the triggering Customer / Invoice / Subscription
  isRead       Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  targetUser User     @relation(fields: [targetUserId], references: [id])

  @@index([businessId])
  @@index([targetUserId])
  @@index([targetUserId, isRead])
}

// Reusable email template (§11.1)
model EmailTemplate {
  id          String            @id @default(cuid())
  businessId  String
  name        String
  type        EmailTemplateType @default(custom)
  subject     String
  bodyHtml    String
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  business  Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)
  campaigns EmailCampaign[]

  @@index([businessId])
}

// One send action, possibly to many recipients (§11 / §11.7)
model EmailCampaign {
  id          String         @id @default(cuid())
  businessId  String
  createdById String
  templateId  String?
  subject     String
  bodyHtml    String
  attachments Json           @default("[]") // [{ filename, path, mimeType, size }]
  segment     Json           @default("{}") // filter criteria used to resolve recipients
  cc          String[]       @default([]) // optional, applied to every recipient in this send
  bcc         String[]       @default([]) // optional, applied to every recipient in this send
  scheduledAt DateTime?
  status      CampaignStatus @default(sending)
  sentCount   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  business  Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy User           @relation(fields: [createdById], references: [id])
  template  EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  logs      EmailLog[]

  @@index([businessId])
  @@index([businessId, status, scheduledAt])
}

// One row per recipient per send (§11.9 / §11.8 tracking)
model EmailLog {
  id                String         @id @default(cuid())
  businessId        String
  campaignId        String? // null for ad-hoc invoice sends
  customerId        String
  to                String
  subject           String
  status            EmailLogStatus @default(queued)
  providerMessageId String? // message ID returned by Resend
  sentAt            DateTime?
  openedAt          DateTime? // set by tracking pixel (§11.8)
  clickedAt         DateTime? // set by redirect click tracking (§11.8)
  bouncedAt         DateTime? // set by Resend webhook (§11.8)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  campaign      EmailCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  customer      Customer       @relation(fields: [customerId], references: [id])
  replyMessages EmailMessage[]

  @@index([businessId])
  @@index([businessId, sentAt])
  @@index([campaignId, status])
  @@index([customerId])
}

// One Gmail mailbox connected per Business (§11.12). Used ONLY for the
// two-way 1:1 reply channel — never for bulk/campaign sending (that's Resend).
model GmailConnection {
  id             String                @id @default(cuid())
  businessId     String                @unique
  emailAddress   String
  accessToken    String // AES-256-GCM encrypted
  refreshToken   String // AES-256-GCM encrypted
  tokenExpiresAt DateTime?
  historyId      String                @default("") // Gmail incremental sync cursor
  status         GmailConnectionStatus @default(connected)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// One row per inbound or outbound message in a Gmail conversation thread (§11.12).
model EmailMessage {
  id                String                @id @default(cuid())
  businessId        String
  customerId        String? // null = inbound message not yet matched to a Customer
  direction         EmailMessageDirection
  gmailMessageId    String                @unique
  gmailThreadId     String
  from              String
  to                String
  subject           String                @default("")
  bodyText          String                @default("")
  bodyHtml          String                @default("")
  sentAt            DateTime?
  receivedAt        DateTime?
  relatedEmailLogId String? // optional link back to the EmailLog this is a reply to
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  business        Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  relatedEmailLog EmailLog? @relation(fields: [relatedEmailLogId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([customerId])
  @@index([gmailThreadId])
  @@index([businessId, customerId])
}

// ── Ad Campaign models (§12c.3) ──────────────────────────────────────────────

// Synced campaign from Facebook or Google.
// One row per unique (adAccountId, externalCampaignId).
model Campaign {
  id                 String     @id @default(cuid())
  businessId         String
  adAccountId        String
  provider           AdProvider
  externalCampaignId String // platform's own campaign ID
  name               String
  objective          String     @default("")
  status             String     @default("") // platform status e.g. ACTIVE / PAUSED / DELETED
  // Ad creative text where available (not all campaign types expose this)
  creativeText       String     @default("") // primary text / body copy
  headline           String     @default("") // ad headline
  startDate          DateTime?
  endDate            DateTime?
  raw                Json       @default("{}") // full raw API response for future use
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  business     Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  adAccount    AdAccount             @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  metrics      CampaignMetric[]
  analyses     AdAnalysis[]
  chatMessages AdChatMessage[]
  keywords     CampaignKeyword[]
  searchTerms  CampaignSearchTerm[]
  targeting    CampaignTargeting?
  demographics CampaignDemographic[]

  @@unique([adAccountId, externalCampaignId])
  @@index([businessId])
  @@index([adAccountId])
}

// Google Ads keyword performance (Google only — Facebook has no keyword concept).
// One row per managed keyword, re-aggregated over the sync window each time (upsert).
model CampaignKeyword {
  id          String   @id @default(cuid())
  businessId  String
  campaignId  String
  text        String
  matchType   String   @default("") // EXACT / PHRASE / BROAD
  status      String   @default("")
  impressions BigInt   @default(0)
  clicks      BigInt   @default(0)
  spend       Decimal? @db.Decimal(14, 4)
  ctr         Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, text, matchType])
  @@index([businessId])
  @@index([campaignId])
}

// Google Ads search terms — the actual queries that triggered the ad (keyword
// expansion / negative-keyword research). Google only.
model CampaignSearchTerm {
  id          String   @id @default(cuid())
  businessId  String
  campaignId  String
  term        String
  impressions BigInt   @default(0)
  clicks      BigInt   @default(0)
  spend       Decimal? @db.Decimal(14, 4)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, term])
  @@index([businessId])
  @@index([campaignId])
}

// Audience / targeting snapshot — who this campaign is aimed at ("tệp khách hàng").
// One row per campaign, replaced on each sync. Facebook: age/gender/geo/interests/
// custom audiences from the adset. Google: age/gender ranges + raw location/language
// criterion ids (not resolved to names — see sync code comment).
model CampaignTargeting {
  id         String     @id @default(cuid())
  businessId String
  campaignId String     @unique
  provider   AdProvider
  ageRanges  Json       @default("[]") // string[] e.g. ["18-24","25-34"]
  genders    Json       @default("[]") // string[] e.g. ["male","female"] or ["all"]
  locations  Json       @default("[]") // string[] — names (FB) or raw criterion ids (Google)
  interests  Json       @default("[]") // [{ id, name }] — Facebook only
  languages  Json       @default("[]") // string[]
  raw        Json       @default("{}")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

// Performance broken down by age/gender(/region) — aggregated over the sync window,
// re-upserted each sync. Lets the AI comment on which audience segment performs best.
model CampaignDemographic {
  id          String   @id @default(cuid())
  businessId  String
  campaignId  String
  ageRange    String   @default("") // '' = not broken down by age
  gender      String   @default("") // '' = not broken down by gender
  region      String   @default("") // '' = not broken down by region
  impressions BigInt   @default(0)
  clicks      BigInt   @default(0)
  spend       Decimal? @db.Decimal(14, 4)
  conversions Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, ageRange, gender, region])
  @@index([businessId])
  @@index([campaignId])
}

// One row per (campaign, date) — daily metric snapshot.
// Nulls are fine when a provider doesn't supply a field.
model CampaignMetric {
  id          String   @id @default(cuid())
  campaignId  String
  date        DateTime // UTC midnight — day-level granularity
  impressions BigInt   @default(0)
  clicks      BigInt   @default(0)
  ctr         Float? // fraction 0–1 (e.g. 0.05 = 5 %)
  spend       Decimal? @db.Decimal(14, 4)
  conversions Float?
  cpc         Decimal? @db.Decimal(14, 4)
  cpa         Decimal? @db.Decimal(14, 4)
  reach       BigInt?
  roas        Float? // return on ad spend = revenue / spend
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([campaignId])
  @@index([campaignId, date])
}

// One OAuth login a staff member made with Facebook or Google (§12c.2).
// Shared APP credentials (FB_APP_ID/SECRET, GOOGLE_CLIENT_ID/SECRET/DEVELOPER_TOKEN) live in .env —
// one operator-owned app for the whole platform. Each staff member who connects gets their OWN
// row here with their OWN access/refresh token, so rate limits are per-user, not shared.
// A single login can expose MANY ad accounts / Pages — those are discovered after connecting
// and stored as separate AdAccount rows under this connection (§ ads architecture).
// Tokens are stored AES-256-GCM encrypted (same key as claude api key).
model AdConnection {
  id             String          @id @default(cuid())
  businessId     String
  userId         String // the staff member who logged in — owns the token
  provider       AdProvider
  accessToken    String // encrypted; for FB this is the long-lived user token
  refreshToken   String          @default("") // encrypted; Google only (FB has no refresh token)
  tokenExpiresAt DateTime? // null = unknown; FB ~60 days, Google ~1 hour
  status         AdAccountStatus @default(active)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  business   Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  adAccounts AdAccount[]

  @@unique([userId, provider])
  @@index([businessId])
  @@index([userId])
}

// One ad account / fanpage discovered under an AdConnection (§ ads architecture).
// A staff member who manages several fanpages gets several AdAccount rows from ONE login —
// no need to re-authenticate per fanpage. Visible to: the connection's owner, anyone granted
// access via AdAccountAccess, and any business owner (who sees every AdAccount in the business).
model AdAccount {
  id                String          @id @default(cuid())
  businessId        String
  connectionId      String // which OAuth connection (token) this account/fanpage belongs to
  provider          AdProvider
  externalAccountId String          @default("") // FB act_xxx / Page id, Google customer id
  accountName       String          @default("") // human-readable label from the platform
  status            AdAccountStatus @default(active) // 'disconnected' = user stopped tracking this one
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  business     Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  connection   AdConnection      @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  campaigns    Campaign[]
  accessGrants AdAccountAccess[]

  @@unique([connectionId, externalAccountId])
  @@index([businessId])
  @@index([connectionId])
}

// Grants a teammate (other than the connection owner) read/sync access to one AdAccount.
// Lets a team share one fanpage's reporting without each person re-connecting OAuth themselves.
model AdAccountAccess {
  id          String   @id @default(cuid())
  adAccountId String
  userId      String
  createdAt   DateTime @default(now())

  adAccount AdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([adAccountId, userId])
  @@index([userId])
}

// AI campaign analysis result (§12c.4). One row per analysis run — history kept so
// users can compare over time.
model AdAnalysis {
  id                  String   @id @default(cuid())
  businessId          String
  campaignId          String
  createdById         String?
  contentReview       String   @default("")
  performanceAnalysis String   @default("")
  audienceAnalysis    String   @default("") // keyword / targeting / customer-segment commentary
  recommendations     Json     @default("[]") // string[]
  model               String   @default("") // Claude model id used
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([campaignId])
  @@index([campaignId, createdAt])
}

// Free-form Q&A thread per campaign — staff can ask anything in any language
// ("what should the ad copy say?", "phân tích chỗ này dùm tôi", etc.) and get a
// reply grounded in this campaign's content + metrics. Separate from AdAnalysis
// (the structured one-click report) — this is an open conversation, kept as history.
model AdChatMessage {
  id          String     @id @default(cuid())
  businessId  String
  campaignId  String
  role        AdChatRole
  content     String
  createdById String? // null for assistant messages
  createdAt   DateTime   @default(now())

  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdBy User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([campaignId])
  @@index([campaignId, createdAt])
}

// Cross-campaign AI analysis — compares several campaigns at once (e.g. all of one
// fanpage's recent ads) and gives combined findings + content recommendations
// informed by what worked across them. campaignIds is a Json string[] rather than a
// join table since this is a point-in-time snapshot, not a live relation.
model AdBatchAnalysis {
  id                  String   @id @default(cuid())
  businessId          String
  campaignIds         Json // string[] — the Campaign ids included in this run
  createdById         String?
  contentReview       String   @default("")
  performanceAnalysis String   @default("")
  audienceAnalysis    String   @default("") // keyword / targeting / customer-segment commentary
  recommendations     Json     @default("[]") // string[]
  model               String   @default("")
  createdAt           DateTime @default(now())

  business     Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy    User?                @relation(fields: [createdById], references: [id], onDelete: SetNull)
  chatMessages AdBatchChatMessage[]

  @@index([businessId])
  @@index([createdById])
}

// Free-form Q&A thread for one cross-campaign analysis run. Users can ask
// follow-up questions after comparing multiple ads, grounded in the saved batch
// analysis + the campaigns included in that comparison.
model AdBatchChatMessage {
  id              String     @id @default(cuid())
  businessId      String
  batchAnalysisId String
  role            AdChatRole
  content         String
  createdById     String?
  createdAt       DateTime   @default(now())

  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  batchAnalysis AdBatchAnalysis @relation(fields: [batchAnalysisId], references: [id], onDelete: Cascade)
  createdBy     User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([batchAnalysisId])
  @@index([batchAnalysisId, createdAt])
}
