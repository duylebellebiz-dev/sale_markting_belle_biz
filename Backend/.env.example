DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/customer_bellebiz_db?schema=public
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
PORT=3000
FRONTEND_URL=http://localhost:5173

# Email fallback (optional)
# Leave these blank if every business sends with its own SMTP mailbox.
# Only required when you want the shared Resend fallback sender enabled.
RESEND_API_KEY=
EMAIL_FROM=

# Public URL of THIS backend — used to build open/click tracking links inside emails.
# Must be reachable by email clients (i.e. not localhost in production).
APP_URL=http://localhost:3000

# Resend webhook signing secret (from Resend dashboard → Webhooks → signing secret).
# Starts with "whsec_".  Required for POST /email/webhook/resend.
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Per-business sender (optional, owner-configurable in Settings → Email Sender).
# When a business enters their own SMTP creds (e.g. Gmail + an App Password),
# campaigns send from that mailbox instead of the shared Resend sender above —
# no domain verification needed. Stored encrypted; CLAUDE_API_ENCRYPTION_SECRET
# below is reused as the generic secrets-at-rest key (not Claude-specific).

# ── AI / Claude API (§12c) ──────────────────────────────────────────────────────
# The owner enters ONE Claude API key in the app's AI Settings screen.
# It is stored encrypted in the database using AES-256-GCM.
# This env var is the 32-byte (64 hex chars) encryption secret — generate once:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Keep it secret; rotate it only if you re-encrypt all existing keys.
# IMPORTANT: if this var is missing or < 64 chars, the encrypt/decrypt helpers throw.
CLAUDE_API_ENCRYPTION_SECRET=your_64_hex_char_secret_here

# ── Ad Account OAuth (§12c.2) ───────────────────────────────────────────────────
# Facebook Ads
# 1. Create a developer app at https://developers.facebook.com/apps/
# 2. Add the "Marketing API" product to your app.
# 3. Set the Valid OAuth Redirect URI to: {APP_URL}/ads/connect/facebook/callback
# 4. Submit for App Review — the "ads_read" scope requires review before production use.
# 5. Once approved, fill in your App ID and Secret below.
FB_APP_ID=your_facebook_app_id
FB_APP_SECRET=your_facebook_app_secret

# Google Ads
# 1. Create OAuth 2.0 credentials at https://console.cloud.google.com/
#    (APIs & Services → Credentials → Create Credentials → OAuth client ID → Web application)
# 2. Enable the Google Ads API in API Library.
# 3. Add the redirect URI: {APP_URL}/ads/connect/google/callback
# 4. Apply for a Google Ads developer token in your Google Ads Manager account:
#    https://developers.google.com/google-ads/api/docs/first-call/dev-token
#    NOTE: requires a Google Ads Manager (MCC) account and passes through approval.
# 5. Fill in credentials below.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token

# The Claude API key itself is NOT stored here — the owner provides it via the UI.
# It is stored encrypted per-business in the database.
# Docs: https://docs.anthropic.com/en/api/getting-started
# Pricing & limits: https://www.anthropic.com/pricing
# Default model used for analysis: claude-sonnet-4-6 (or latest Sonnet/Haiku for cost)
# Never expose API keys to the frontend — all Claude calls are server-side only.
